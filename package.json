{
  "name": "botium-connector-nuance",
  "version": "1.0.6",
  "description": "Botium Connector for Nuance",
  "type": "module",
  "main": "dist/botium-connector-nuance-cjs.cjs",
  "module": "dist/botium-connector-nuance-es.js",
  "exports": {
    ".": {
      "import": "./dist/botium-connector-nuance-es.js",
      "require": "./dist/botium-connector-nuance-cjs.cjs",
      "default": "./dist/botium-connector-nuance-cjs.cjs"
    }
  },
  "bin": {
    "botium-connector-botium-connector-nuance-cli": "./bin/cli.js"
  },
  "scripts": {
    "build": "rollup -c",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build",
    "eslint": "eslint index.js bin/**/*.js src/**/*.js",
    "eslint-fix": "eslint --fix index.js bin/**/*.js src/**/*.js",
    "test": "mocha test/unittest/**/*spec.js",
    "test-nightly": "mocha test/nightly/**/*spec.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codeforequity-at/botium-connector-nuance.git"
  },
  "author": "Botium GmbH",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/codeforequity-at/botium-core/issues"
  },
  "homepage": "https://www.botium.ai",
  "devDependencies": {
    "axios-mock-adapter": "^1.21.2",
    "chai": "^4.3.7",
    "chai-as-promised": "^7.1.1",
    "dotenv": "^16.0.3",
    "eslint": "^7.32.0",
    "eslint-config-standard": "^14.1.0",
    "eslint-plugin-import": "^2.22.1",
    "eslint-plugin-mocha": "^10.1.0",
    "eslint-plugin-node": "^10.0.0",
    "eslint-plugin-promise": "^4.2.1",
    "eslint-plugin-standard": "^4.0.1",
    "grpc-tools": "^1.12.4",
    "mocha": "^10.2.0",
    "rollup": "^2.10.9",
    "rollup-plugin-copy": "^3.5.0",
    "rollup-plugin-json": "^4.0.0"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.8.13",
    "@grpc/proto-loader": "^0.7.6",
    "adm-zip": "^0.5.10",
    "axios": "^1.3.5",
    "debug": "^4.3.4",
    "google-proto-files": "^4.2.0",
    "lodash": "^4.17.21",
    "mkdirp": "^1.0.4",
    "qs": "^6.11.1",
    "slug": "^5.1.0",
    "xml-js": "^1.6.11",
    "yargs": "^17.6.2"
  }
}
